# Locus Configuration Example
# Copy this file to .env and adjust as needed.
# All variables are prefixed with LOCUS_

# Directory where the engine infrastructure resides (default: .engine)
# LOCUS_ENGINE_DIR=.engine

# LLM Provider and Model (can also be set via CLI options)
# LOCUS_PROVIDER=claude
# LOCUS_MODEL=sonnet
# LOCUS_MODE=plan
# LOCUS_OUTPUT_FORMAT=text

# MCP Server API Keys (required for agent documentation access)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxx
# CONTEXT7_API_KEY=ctx7sk-xxx

# Notion Integration (optional — enables idea intake and status synchronization)
# NOTION_TOKEN=secret_xxx                         # Notion internal integration token
# LOCUS_NOTION_IDEAS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # DB for incoming ideas
# LOCUS_NOTION_SPECS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # DB for registered proposals
# LOCUS_NOTION_DOCS_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx      # DB for official documentation
# LOCUS_NOTION_GUIDES_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx    # DB for process guides

# Obsidian Integration (optional — enables vault context during design/specify)
# LOCUS_OBSIDIAN_VAULT_PATH=/path/to/your/vault
